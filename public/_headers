# Cache rules for Kalatháki (Render / Netlify / Cloudflare Pages)
# index.html — NEVER cache so every deploy is picked up immediately
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Vite assets — content-hashed filenames, safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker — must always be revalidated
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# PWA manifest
/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate

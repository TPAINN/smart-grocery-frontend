# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
.env.example

# ── Dependencies (NEVER commit these) ─────────────────────────────────────────
node_modules/

# ── Build output (generated by CI/Vite, not committed) ────────────────────────
dist/

# ── AI / Editor config (local only) ──────────────────────────────────────────
.claude/
.cursor/
.vscode/
.idea/

# ── One-off migration / redesign scripts ─────────────────────────────────────
redesign_*.mjs
redesign_*.js

# ── Android build artifacts (generated by Gradle) ────────────────────────────
android/app/build/
android/.gradle/
android/local.properties
android/keystore.properties
android/app/*.jks
android/app/*.keystore

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
